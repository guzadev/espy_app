{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Espy",
  "version": "0.3.0",
  "identifier": "com.espyapp.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Espy",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "wix": {
        "upgradeCode": "4e8a7f2d-1c3b-4d5e-8f9a-2b6c0e7d4f1a"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/guzadev/espy_app/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzNjQyQTg2NzI1NEM5NQpSV1NWVENWbnFFSTJEVFJ4anBvcUNRaXJSVjJGbHJ3WEJEdnFaUFhvc28rR0JrUWhJMUc0MEFveQo="
    }
  }
}
